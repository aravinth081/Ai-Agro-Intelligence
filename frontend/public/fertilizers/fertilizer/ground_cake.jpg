<script>
  $(document).ready(function () {
      // Initialize the carousel
      $("#carouselIndicators").carousel({
          interval: 2000
      });

      // Swipe gesture support for the carousel
      $("#carouselIndicators").swipe({
          swipe: function (event, direction, distance, duration, fingerCount, fingerData) {
              if (direction === 'left') {
                  $(this).carousel('next');
              } else if (direction === 'right') {
                  $(this).carousel('prev');
              }
          },
          allowPageScroll: "vertical"
      });

      // Open image in a popup on click
      $(".image-popup").magnificPopup({
          type: 'image',
          gallery: {
              enabled: true
          }
      });

      // Optional: Move carousel to image on click (if needed)
      function moveCarouselToImage(imageIndex) {
          $("#carouselIndicators").carousel(imageIndex);
      }

      $(document).on("click", ".image-container", function () {
          var imageIndex = $(this).index() + 1;
          moveCarouselToImage(imageIndex);
      });
  });
</script>

