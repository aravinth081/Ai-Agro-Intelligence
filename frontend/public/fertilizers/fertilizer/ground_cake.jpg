<style>
  .navbar {
    height: 100%;
    width: 0px;
    position: absolute;
    z-index: 999;
    top: 0px;
    right: 0px;
    background-color: white;
    overflow-x: hidden;
    transition: 0.5s;
    padding-top: 60px;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    display: none;
  }
  .navbar a,
  .dropdown-btn {
    padding: 10px 20px;
    border: none;
    background-color: #fff;
    text-decoration: none;
    font-size: 18px;
    color: darkgrey;
    display: block;
    transition: 0.3s;
  }

  .navbar .closebtn {
    position: absolute;
    padding: 0px;
    top: 10px;
    right: 35px;
    font-size: 36px;
  }

  .dropdown-container {
    display: none;
    z-index: 9999;
    background-color: white;
    padding-left: 20px;
  }

  .open {
    display: block;
  }

  .top-navbar {
    display: none;
    background-color: white;
    overflow: hidden;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    justify-content: center;
    align-items: center;
  }

  .top-navbar a {
    float: left;
    display: block;
    color: #555;
    text-align: center;
    padding: 14px 20px;
    text-decoration: none;
    font-size: 17px;
  }

  .btn {
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
    border-radius: 10px;
  }

  .inner {
    width: 100%;
    background-color: #d6f6e4 !important;
  }

  .inner-inside {
    width: 100%;
    background-color: #e7f4ed !important;
  }

  .icon {
    margin-right: 10px;
  }

  .top-right-buttons {
    display: flex;
    padding: 10px 20px;
    justify-content: flex-start;
    align-items: center;
    gap: 10px;
    margin-top: 10px;
  }

  .top-right-buttons a {
    text-decoration: none;
    color: darkgrey;
    padding: 10px;
    border: 1px solid darkgrey;
    border-radius: 5px;
  }

  .mobile-item:hover {
    background-color: lightgray;
  }
  .openbtn {
    font-size: 25px;
    cursor: pointer;
    background-color: white;
    color: black;
    padding: 10px 15px;
    border: none;
    border-radius: 5px;
  }

  .logo {
    text-align: center;
    padding: 10px 0;
    font-size: 24px;
    font-weight: bold;
    color: darkgrey;
  }

  .menu ul {
    list-style-type: none;
    padding: 0;
    margin: 0;
    display: flex;
  }

  .menu li {
    position: relative;
  }

  .menu a {
    text-decoration: none;
    display: block;
    padding: 10px;
    color: #000;
  }

  .menu .logo {
    order: 0;
    flex: 1;
  }

  .menu .submenu {
    display: none;
    position: absolute;
    top: 100%;
    z-index: 999;
    left: 0;
    list-style-type: none;
    padding: 0;
    margin: 0;
    background-color: #fff;
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
  }

  .menu .submenu .submenu {
    top: 0;
    left: 100%;
  }

  .menu .submenu li {
    width: 200px;
  }

  .menu .arrow {
    cursor: pointer;
    padding: 10px;
    font-size: 12px;
    user-select: none;
  }

  .menu .arrow:hover {
    color: #007bff;
  }

  .menu li:hover > .submenu {
    display: block;
  }

  @media screen and (min-width: 1200px) {
    .navbar {
      display: none;
    }

    .menu {
      display: flex;
    }

    .top-right-buttons {
      margin-top: 0;
    }

    .top-navbar .logo {
      order: 0;
      flex: 1;
    }

    .top-navbar .menu-items {
      display: flex;
      flex: 2;
      justify-content: center;
      order: 1;
    }

    .top-navbar .menu-items a {
      padding: 14px 20px;
    }

    .search-box {
      background: #fff;
      padding: 15px;
      border: 2px solid #5cc48a;
      border-radius: 25px;
      box-shadow: bisque;
      -webkit-box-shadow: 0px 0px 7px 0px rgba(41, 117, 65, 1);
      align-items: center;
      min-width: 250px;
      height: 35px;
    }
  }

  @media screen and (max-width: 1200px) {
    .menu {
      display: none;
    }
  }
</style>


    <div
        class="d-flex justify-content-center w-100 d-md-none d-block"
        style="background-color: rgb(239, 238, 238); position: relative;"
    >
        <form id="search-form-phone" action="/products/" method="GET" class="w-100 d-flex justify-content-center">
            <input type="text" id="search-phone-index" name="q" placeholder="Search products..." class="rounded-pill" />
        </form>
        <div id="search-results-dropdown" style="position: absolute; top: 100%; left: 2.5%; width: 95%; background-color: #fff; border: 1px solid #e0e0e0; border-radius: 8px; box-shadow: 0 6px 18px rgba(0, 0, 0, 0.15); max-height: 300px; overflow-y: auto; z-index: 1000; display: none;"></div>
        <style>
            #search-phone-index {
                transition: all 0.3s ease-in-out;
                margin: 15px 0px;
                border: 1px solid #ccc;
                height: 30px;
                padding: 1.1rem;
                width: 95%;
                font-size: 16px;
                color: #333;
                border-radius: 25px; /* Added border-radius for consistency */
            }
            #search-phone-index:focus {
                outline: none;
                border-color: #5cb85c;
                -webkit-box-shadow: 0px 0px 12px 3px rgba(92, 184, 92, 0.6); /* Adjusted shadow */
                -moz-box-shadow: 0px 0px 12px 3px rgba(92, 184, 92, 0.6);
                box-shadow: 0px 0px 12px 3px rgba(92, 184, 92, 0.6);
            }
            #search-results-dropdown div {
                padding: 14px 18px; /* Increased padding */
                cursor: pointer;
                border-bottom: 1px solid #e8e8e8; /* Slightly darker border */
                font-size: 16px; /* Slightly larger font size */
                color: #444; /* Slightly darker text color */
                display: flex;
                align-items: center;
                transition: background-color 0.2s ease; /* Smooth hover transition */
            }
            #search-results-dropdown div:last-child {
                border-bottom: none;
            }
            #search-results-dropdown div:hover {
                background-color: #f0f0f0; /* Lighter hover background */
                color: #222; /* Darker text on hover */
            }
            #search-results-dropdown div img { /* Style for product images in dropdown */
                width: 45px; /* Slightly larger image */
                height: 45px;
                margin-right: 12px; /* Increased margin */
                border-radius: 5px; /* Slightly larger border-radius */
                object-fit: cover;
                box-shadow: 0 2px 5px rgba(0,0,0,0.08); /* Added subtle shadow to image */
            }
        </style>
    </div>

    <script>
        $(document).ready(function() {
            var searchTimeout;
            $('#search-phone-index').on('keyup', function() {
                clearTimeout(searchTimeout);
                var query = $(this).val();
                var searchResultsDropdown = $('#search-results-dropdown');
                
                if (query.length > 2) {
                    searchTimeout = setTimeout(function() {
                        $.ajax({
                            url: "/products/search-products-ajax/",
                            data: { 'q': query },
                            dataType: 'json',
                            success: function(data) {
                                searchResultsDropdown.empty();
                                if (data.products && data.products.length > 0) {
                                    $.each(data.products, function(index, product) {
                                        var imageUrl = product.image_url ? product.image_url : "/static/images/default-product-image.png"; // Default image if none
                                        searchResultsDropdown.append(
                                            '<div data-slug="' + product.slug + '">' +
                                                '<img src="' + imageUrl + '" alt="' + product.name + '">' +
                                                '<span>' + product.name + '</span>' +
                                            '</div>'
                                        );
                                    });
                                    searchResultsDropdown.show();
                                } else {
                                    searchResultsDropdown.hide();
                                }
                            }
                        });
                    }, 300);
                } else {
                    searchResultsDropdown.hide();
                }
            });

            // Removed keydown listener from input, now handled by form submit

            $(document).on('click', '#search-results-dropdown div', function() {
                var productName = $(this).text();
                var productSlug = $(this).data('slug');
                $('#search-phone-index').val(productName);
                $('#search-results-dropdown').hide();
                window.location.href = "/products/PLACEHOLDER/".replace('PLACEHOLDER', productSlug);
            });

            $(document).on('click', function(event) {
                if (!$(event.target).closest('#search-phone-index').length && !$(event.target).closest('#search-results-dropdown').length) {
                    $('#search-results-dropdown').hide();
                }
            });
        });
    </script>
    
  
