                <script>

                  document.addEventListener('DOMContentLoaded', function () {
                    const varianceButtons = document.querySelectorAll('.variance-button');

                    const isStock = "True" == "False" ? false : true;
                    if (!isStock) {
                      document.getElementById("add-to-cart").style.display = "none";
                    }

                    varianceButtons.forEach(button => {
                      button.addEventListener('click', function () {
                        varianceButtons.forEach(btn => btn.classList.remove('active-var'));
                        button.classList.add('active-var');

                        // Update the hidden radio input for the variance
                        document.getElementById(button.dataset.target).checked = true;

                        // Call the function to update product details based on the selected variance
                        varianceSelected(button);
                      });
                    });
                  });

                  function updateStockInfo(stock) {
                    const stockInfo = document.querySelector('.stock-info');
                    if (stock > 0) {
                      if (stock < 10) {
                        stockInfo.innerHTML = `There are only <span class="font-weight-bold text-warning">${stock}</span> items left`;
                        stockInfo.className = 'm-0 text-info stock-info';
                        document.getElementById("add-to-cart").style.display = "block";
                      } else {
                        stockInfo.innerText = 'In Stock';
                        stockInfo.className = 'm-0 font-weight-bold text-success stock-info';
                        document.getElementById("add-to-cart").style.display = "block";
                      }
                    } else {
                      stockInfo.innerText = 'Out of Stock';
                      stockInfo.className = 'm-0 text-danger font-weight-bold stock-info';
                      document.getElementById("add-to-cart").style.display = "none";
                    }
                  }

                  function varianceSelected(button) {
                    var input = document.getElementById(button.dataset.target);

                    var price = input.getAttribute('data-price');
                    var price_with_tax = input.getAttribute('data-price-with-tax');
                    var discount = input.getAttribute('data-discount');
                    var amountSaved = input.getAttribute('data-amount-saved');
                    var stock = parseInt(input.getAttribute('data-stock'));

                    document.querySelector('.price span').innerText = '₹' + price;
                    updateStockInfo(stock);

                    var discountElement = document.querySelector('.discount-info');
                    var fake_price = document.querySelector('.fake-price');
                    var free_delivery_info = document.querySelector('.free-delivery-info');

                    if (free_delivery_info) {
                      if (price >= parseFloat("699")) {
                        free_delivery_info.style.display = 'block';
                      } else {
                        free_delivery_info.style.display = 'none';
                      }
                    }

                    if (discount > 0) {
                      discountElement.style.display = 'block';
                      fake_price.style.display = 'block';
                      discountElement.innerText = 'You Saved: ₹' + amountSaved;
                      fake_price.innerText = '₹' + price_with_tax;
                    } else {
                      discountElement.style.display = 'none';
                      fake_price.style.display = 'none';
                    }

                    var number_of_seeds = document.getElementById("number_of_seeds");
                    if (number_of_seeds) {
                      number_of_seeds.innerText = input.getAttribute('data-number-of-seeds');
                    }
                  }

                  document.getElementById("add-to-cart").addEventListener("click", function (event) {
                    event.preventDefault();
                    document.getElementById("productForm").submit();
                  });

                  function ProductincrementQuantity() {
                    var quantityInput = document.getElementById("quantity");
                    console.log(quantityInput)
                    var currentValue = parseInt(quantityInput.value);
                    if (currentValue < 50) {
                      quantityInput.value = currentValue + 1;
                    }
                  }

                  function ProductdecrementQuantity() {
                    var quantityInput = document.getElementById("quantity");
                    var currentValue = parseInt(quantityInput.value);
                    if (currentValue > 1) {
                      quantityInput.value = currentValue - 1;
                    }
                  }

                  $(".review-rating").starRating({
                    readOnly: true,
                    starSize: 15,
                  });

                </script>
  


