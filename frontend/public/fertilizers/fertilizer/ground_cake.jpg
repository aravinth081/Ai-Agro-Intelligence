<div id="dynamic-snackbar" style="display: none; position: fixed; bottom: 20px; left: 20px; background-color: rgba(64, 64, 64, 0.8); color: white; padding: 1rem; border-radius: 8px; box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15); z-index: 1000; font-family: 'Poppins', Arial, sans-serif; max-width: 350px; backdrop-filter: blur(5px);">
    <span id="snackbar-close" style="position: absolute; top: 5px; right: 10px; color: #ccc; font-size: 20px; cursor: pointer;">&times;</span>
    <a id="snackbar-link" href="#" style="text-decoration: none; color: inherit;">
        <div style="display: flex; align-items: center;">
            <img id="snackbar-image" src="" alt="" style="width: 60px; height: 60px; object-fit: cover; border-radius: 6px; margin-right: 1rem;">
            <div>
                <p id="snackbar-name" style="margin: 0; font-size: 1em; line-height: 1.3;">
                    <strong></strong>
                </p>
                <p id="snackbar-text" style="margin: 5px 0 0 0; font-size: 0.9em; line-height: 1.2;">
                    Someone just bought <em><span id="snackbar-count"></span> pieces</em> in the last <span id="snackbar-time-window"></span> <span id="snackbar-time-unit">hours!</span>
                </p>
            </div>
        </div>
    </a>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        var snackbar = document.getElementById('dynamic-snackbar');
        var snackbarClose = document.getElementById('snackbar-close');
        var snackbarLink = document.getElementById('snackbar-link');
        var snackbarImage = document.getElementById('snackbar-image');
        var snackbarName = document.getElementById('snackbar-name');
        var snackbarCount = document.getElementById('snackbar-count');
        var snackbarTimeWindow = document.getElementById('snackbar-time-window');
        var snackbarTimeUnit = document.getElementById('snackbar-time-unit'); // Added
        var snackbarInterval;

        function updateSnackbarContent(data) {
            if (data) {
                snackbarLink.href = data.url;
                snackbarImage.src = data.image_url || '';
                snackbarImage.alt = data.name || '';
                snackbarName.querySelector('strong').textContent = data.name || 'Special Offer Item';
                snackbarCount.textContent = data.count || 'a few';
                var timeValue = parseInt(data.time_window || '1'); // Default to 1 for singular "hour"
                snackbarTimeWindow.textContent = timeValue;
                if (timeValue === 1) {
                    snackbarTimeUnit.textContent = 'hour!';
                } else {
                    snackbarTimeUnit.textContent = 'hours!';
                }
            }
        }

        function fetchAndShowSnackbar() {
            fetch('/get_random_product_data/')
                .then(response => response.json())
                .then(data => {
                    updateSnackbarContent(data);
                    if (snackbar) {
                        snackbar.style.display = 'block';
                    }
                })
                .catch(error => console.error('Error fetching snackbar data:', error));
        }

        function hideSnackbar() {
            if (snackbar) {
                snackbar.style.display = 'none';
            }
        }

        if (snackbar) {
            // Initial fetch and show after 5 seconds
            setTimeout(fetchAndShowSnackbar, 5000);

            // Fetch new data and toggle visibility every 10 seconds after the initial show
            snackbarInterval = setInterval(function() {
                if (snackbar.style.display === 'none') {
                    fetchAndShowSnackbar();
                } else {
                    hideSnackbar();
                }
            }, 10000); // 10 seconds

            snackbarClose.addEventListener('click', function(event) {
                event.preventDefault(); // Prevent link click if close button is inside the link
                hideSnackbar();
                clearInterval(snackbarInterval);
            });
        }
    });
</script>
  </body>
</html>
