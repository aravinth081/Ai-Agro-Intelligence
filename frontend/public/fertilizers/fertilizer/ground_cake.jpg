<div class="bottom-sheet">
  <div class="content p-3" style="background-image: url(/static/loginbg.png);">
    <div class="header flex-column align-items-center">
      <div class="drag-icon"><span></span></div>
      <h3 class="text-center d-none d-sm-block">Welcome to Golden Hills Farm</h3>
      <h3 class="text-center d-sm-none">Welcome to<br>Golden Hills Farm</h3>
      <p class="text-center text-dark">Sign in now to receive a <span class="font-weight-bold">5%</span> instant discount on your first order when using code <span class="font-weight-bold text-primary">WELCOME</span>. Begin your organic journey today!</p>
      <button type="button" class="close-button" onclick="hideBottomSheet()">×</button>
    </div>
    <div class="body d-flex flex-column align-items-center">
      <div id="loginForm" style="width: 50%;">
        <form id="sendOTPForm" class="needs-validation" novalidate onsubmit="sendOTP(event)">
          <input type="hidden" name="csrfmiddlewaretoken" value="gDL5JyzpdUaGeKFHba0FqV958opYbUcsuYo7E1ivutQRZdhsLwa2zlh7xlhP8rtB">
          <input
            type="tel"
            name="phone"
            id="phone"
            class="form-control my-3"
            style="font-size: 14px; padding: 8px; margin-bottom: 8px;"
            placeholder="Phone Number"
            required
          />
          <div class="invalid-feedback" style="font-size: 12px">Please provide a valid phone number.</div>
          <button
            type="submit"
            id="sendOTPButton"
            class="btn btn-primary w-100"
            style="font-size: 14px; padding: 8px 12px"
          >
            Send OTP
          </button>
          <div id="otpLoadingIndicator" class="text-center mt-2" style="display: none;">
            Sending OTP...
          </div>
        </form>
      </div>
      <div id="otpForm" style="display: none;">
        <h2 style="font-size: 16px; margin-bottom: 5px">OTP will be sent to your phone number</h2>
        <form id="verifyOTPForm" class="needs-validation" novalidate onsubmit="verifyOTP(event)">
          <input type="hidden" name="csrfmiddlewaretoken" value="gDL5JyzpdUaGeKFHba0FqV958opYbUcsuYo7E1ivutQRZdhsLwa2zlh7xlhP8rtB">
          <input type="hidden" name="phone" id="phoneConfirm" value="" />
          <input
            type="number"
            name="otp"
            id="otp"
            class="form-control my-3"
            style="font-size: 14px; padding: 8px; margin-bottom: 8px"
            placeholder="OTP"
            required
          />
          <div class="invalid-feedback" style="font-size: 12px">Please enter the OTP sent to your phone.</div>
          <button
            type="submit"
            class="btn btn-primary w-100"
            style="font-size: 14px; padding: 8px 12px"
          >
            Verify OTP
          </button>
        </form>
      </div>
      <p class="text-center text-dark" style="position: absolute; bottom: 10px;">
        By logging in, you're agreeing to our <a href="/docs/terms" target="_blank">Terms of Service</a> and <a href="/docs/privacy" target="_blank">Privacy Policy</a>.
      </p>
    </div>
  </div>
</div>
<script src="/static/js/bottom-sheet.js"></script>

<script>
  function isValidPhoneNumber(phone) {
    const phoneRegex = /^[+]?[0-9]{10}$/;
    return phoneRegex.test(phone);
  }

  function sendOTP(event) {
    event.preventDefault();
    const phoneInput = document.getElementById('phone');
    const sendOTPButton = document.getElementById('sendOTPButton');
    const otpLoadingIndicator = document.getElementById('otpLoadingIndicator');
    const phone = phoneInput.value.trim();
    
    if (!isValidPhoneNumber(phone)) {
      phoneInput.setCustomValidity('Please enter a valid phone number.');
      phoneInput.reportValidity();
      return;
    } else {
      phoneInput.setCustomValidity('');
    }

    if (phoneInput.checkValidity()) {
      // Hide the button and show loading indicator
      sendOTPButton.style.display = 'none';
      otpLoadingIndicator.style.display = 'block';

      fetch('/api/auth/send-otp/', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRFToken': document.querySelector('[name=csrfmiddlewaretoken]').value
        },
        body: JSON.stringify({ phone: phone })
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          console.log('OTP sent successfully');
          document.getElementById('phoneConfirm').value = phone;
          document.getElementById('loginForm').style.display = 'none';
          document.getElementById('otpForm').style.display = 'block';
        } else {
          console.error('Failed to send OTP:', data.error);
          alert('Failed to send OTP: ' + data.error);
          // Show the button again and hide loading indicator
          sendOTPButton.style.display = 'block';
          otpLoadingIndicator.style.display = 'none';
        }
      })
      .catch(error => {
        console.error('Error:', error);
        alert('An error occurred while sending OTP. Please try again.');
        // Show the button again and hide loading indicator
        sendOTPButton.style.display = 'block';
        otpLoadingIndicator.style.display = 'none';
      });
    } else {
      phoneInput.reportValidity();
    }
  }

  function verifyOTP(event) {
    event.preventDefault();
    const otpInput = document.getElementById('otp');
    const phone = document.getElementById('phoneConfirm').value.trim();
    const otp = otpInput.value.trim();

    if (otp.length !== 6) {
      otpInput.setCustomValidity('OTP must be 6 digits.');
      otpInput.reportValidity();
      return;
    } else {
      otpInput.setCustomValidity('');
    }

    if (otpInput.checkValidity()) {
      fetch(`/api/auth/verify_otp/${phone}/`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRFToken': document.querySelector('[name=csrfmiddlewaretoken]').value
        },
        body: JSON.stringify({ otp: otp })
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          console.log('OTP verified successfully');
          hideBottomSheet();
          updateUIForLoggedInUser();
        } else {
          console.error('Failed to verify OTP:', data.message);
          alert('Failed to verify OTP: ' + data.message);
        }
      })
      .catch(error => console.error('Error:', error));
    } else {
      otpInput.reportValidity();
    }
  }

  function updateUIForLoggedInUser() {
    document.querySelectorAll('.logged-out-only').forEach(el => el.style.display = 'none');
    document.querySelectorAll('.logged-in-only').forEach(el => el.style.display = 'block');
  }

  
  document.addEventListener("DOMContentLoaded", function() {
    setTimeout(showBottomSheet, 120000);
  });
  
</script>

