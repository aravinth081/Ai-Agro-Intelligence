        <div class="d-none d-md-flex justify-content-center align-items-center" style="position: relative;">
            <form id="search-form-pc" action="/products/" method="GET" class="d-flex align-items-center">
                <input
                    type="text"
                    class="search-box"
                    style="height: 30px; border: 1px solid #ccc; font-size: 16px; color: #333;"
                    id="search-pc-index"
                    name="q"
                    placeholder="Search products..."
                />
            </form>
            <div id="search-results-dropdown-pc" style="position: absolute; top: 100%; left: 0; width: 100%; background-color: #fff; border: 1px solid #dcdcdc; border-radius: 12px; box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2); max-height: 280px; overflow-y: auto; z-index: 1000; display: none; padding: 12px; margin-top: 8px;"></div>
        </div>
        <script>
            $(document).ready(function() {
                var searchTimeoutPc;
                $('#search-pc-index').on('keyup', function() {
                    clearTimeout(searchTimeoutPc);
                    var query = $(this).val();
                    var searchResultsDropdownPc = $('#search-results-dropdown-pc');

                    if (query.length > 2) {
                        searchTimeoutPc = setTimeout(function() {
                            $.ajax({
                                url: "/products/search-products-ajax/",
                                data: { 'q': query },
                                dataType: 'json',
                                success: function(data) {
                                    searchResultsDropdownPc.empty();
                                    if (data.products && data.products.length > 0) {
                                        $.each(data.products, function(index, product) {
                                            var imageUrl = product.image_url ? product.image_url : "/static/images/default-product-image.png"; // Default image if none
                                            searchResultsDropdownPc.append('<div class="search-result-item" data-slug="' + product.slug + '"><img src="' + imageUrl + '" alt="' + product.name + '" class="search-result-image"><span class="search-result-name">' + product.name + '</span></div>');
                                        });
                                        searchResultsDropdownPc.show();
                                    } else {
                                        searchResultsDropdownPc.hide();
                                    }
                                }
                            });
                        }, 300);
                    } else {
                        searchResultsDropdownPc.hide();
                    }
                });

                $(document).on('click', '#search-results-dropdown-pc div', function() {
                    var productName = $(this).text();
                    var productSlug = $(this).data('slug');
                    $('#search-pc-index').val(productName);
                    $('#search-results-dropdown-pc').hide();
                    window.location.href = "/products/PLACEHOLDER/".replace('PLACEHOLDER', productSlug);
                });

                $(document).on('click', function(event) {
                    if (!$(event.target).closest('#search-pc-index').length && !$(event.target).closest('#search-results-dropdown-pc').length) {
                        $('#search-results-dropdown-pc').hide();
                    }
                });
            });
        </script>
        <style>
            .search-result-item {
