                align-items: center;
                padding: 5px;
                cursor: pointer;
                border-bottom: 1px solid #eee;
                transition: background-color 0.2s ease;
                color: #333;
            }
            .search-result-item:last-child {
                border-bottom: none;
            }
            .search-result-item:hover {
                background-color: #f5f5f5;
                color: #007bff;
