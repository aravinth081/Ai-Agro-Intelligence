<h3>Foliar Application</h3>
<table>
<thead>
<tr>
<th class="dt_colhead">Crop</th>
<th class="dt_colhead">Application date</th>
<th class="dt_colhead">Min kg / ha / appl</th>
<th class="dt_colhead">Max kg / ha / appl</th>
<th class="dt_colhead">Conc. % (w/v))</th>
</tr>
</thead>
<tbody>
<tr>
<td>Vegetables<br /><img width="100" height="57" src="https://www.vaniperen.com/wp-content/uploads/2017/05/Tomatoes20-20green20beans20crop@10x-100x57.png" class="attachment-super_small size-super_small" alt="" decoding="async" loading="lazy" srcset="https://www.vaniperen.com/wp-content/uploads/2017/05/Tomatoes20-20green20beans20crop@10x-100x57.png 100w, https://www.vaniperen.com/wp-content/uploads/2017/05/Tomatoes20-20green20beans20crop@10x.png 200w" sizes="auto, (max-width: 100px) 100vw, 100px" /></td>
<td>• As of vegetative growth<br />• Until 4 weeks before harvesting</td>
<td>3</td>
<td>6</td>
<td>0.5 - 1.0</td>
</tr>
<tr>
<td>Citrus	<br /><img width="100" height="89" src="https://www.vaniperen.com/wp-content/uploads/2017/06/Citrus20crop20hor@10x-100x89.png" class="attachment-super_small size-super_small" alt="" decoding="async" loading="lazy" srcset="https://www.vaniperen.com/wp-content/uploads/2017/06/Citrus20crop20hor@10x-100x89.png 100w, https://www.vaniperen.com/wp-content/uploads/2017/06/Citrus20crop20hor@10x.png 200w" sizes="auto, (max-width: 100px) 100vw, 100px" /></td>
<td>1 - 2 applications:<br />• As of fruit setting<br />• Until fruit filling</td>
<td>6</td>
<td>15</td>
<td>1.0 - 1.5</td>
</tr>
<tr>
<td>Olive<br /><img width="100" height="72" src="https://www.vaniperen.com/wp-content/uploads/2017/04/Olive20crop@10x-100x72.png" class="attachment-super_small size-super_small" alt="" decoding="async" loading="lazy" srcset="https://www.vaniperen.com/wp-content/uploads/2017/04/Olive20crop@10x-100x72.png 100w, https://www.vaniperen.com/wp-content/uploads/2017/04/Olive20crop@10x.png 200w" sizes="auto, (max-width: 100px) 100vw, 100px" /></td>
<td>2 - 4 applications:<br />• Until flowering starts<br />• During fruit setting</td>
<td>4</td>
<td>12</td>
<td>1.0 - 1.5</td>
</tr>
<tr>
<td>Stone fruit<br /><img width="100" height="66" src="https://www.vaniperen.com/wp-content/uploads/2017/04/Peach20crop@10x-100x66.png" class="attachment-super_small size-super_small" alt="" decoding="async" loading="lazy" srcset="https://www.vaniperen.com/wp-content/uploads/2017/04/Peach20crop@10x-100x66.png 100w, https://www.vaniperen.com/wp-content/uploads/2017/04/Peach20crop@10x.png 200w" sizes="auto, (max-width: 100px) 100vw, 100px" /></td>
<td>1 - 3 applications:<br />• As of end of flowering<br />• Until fruit filling</td>
<td>5</td>
<td>10</td>
<td>0.5 - 1.0</td>
</tr>
<tr>
<td>Pip fruit<br /><img width="100" height="82" src="https://www.vaniperen.com/wp-content/uploads/2017/04/Apple20crop@10x-100x82.png" class="attachment-super_small size-super_small" alt="" decoding="async" loading="lazy" srcset="https://www.vaniperen.com/wp-content/uploads/2017/04/Apple20crop@10x-100x82.png 100w, https://www.vaniperen.com/wp-content/uploads/2017/04/Apple20crop@10x.png 200w" sizes="auto, (max-width: 100px) 100vw, 100px" /></td>
<td>1 - 3 applications:<br />• As of end of flowering<br />• Until fruit filling</td>
<td>4</td>
<td>12</td>
<td>0.5 - 1.0</td>
</tr>
</tbody>
</table>
